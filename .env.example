# Variables de entorno para el Frontend (F1-frontend)
# Copia este archivo como .env.local para desarrollo local fuera de Docker.
# En Heroku, configura con: heroku config:set KEY=value ANTES del primer deploy.

# URL pública del API backend.
# IMPORTANTE: Esta variable se bake en el bundle de Next.js en tiempo de build.
# - Desarrollo local:  http://localhost:4000
# - Producción Heroku: https://<nombre-app-api>.herokuapp.com
NEXT_PUBLIC_API_BASE=http://localhost:4000
